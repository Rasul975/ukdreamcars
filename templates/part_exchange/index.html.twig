{% extends 'base.html.twig' %}

{% block title %}Part Exchange{% endblock %}

{% block body %}
    <div class="container container-fluid-custom custom2 my-5">
        <h1 class="mb-4">Part Exchange</h1>

        {{ form_start(form) }}
        <div class="row">
            <div class="col-md-6">
                <h2>Your Personal Details</h2>
                <div class="mb-3">
                    {{ form_row(form.name) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.email) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.phone) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.interestedIn) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.message) }}
                </div>
            </div>
            <div class="col-md-6">
                <h2>Your Vehicle Details</h2>
                <div class="mb-3">
                    {{ form_row(form.makeModel) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.registration) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.mileage) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.transmission) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.fuelType) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.exteriorColour) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.interiorColour) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.interiorFinish) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.fullServiceHistory) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.lastServiced) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.previousOwners) }}
                </div>
                <div class="mb-3">
                    {{ form_row(form.condition) }}
                </div>
            </div>
        </div>

        <div class="form-group mt-4">
            <button type="submit" class="btn btn-primary">Submit</button>
        </div>
        {{ form_end(form) }}
    </div>
{% endblock %}
