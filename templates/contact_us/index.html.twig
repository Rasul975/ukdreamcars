{# templates/contact/contact.html.twig #}

{% extends 'base.html.twig' %}

{% block title %}Contact Us{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1>Contact Us</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        {{ form_start(contactForm) }}
        {{ form_errors(contactForm) }}

        <div class="form-group">
            {{ form_label(contactForm.name) }}
            {{ form_widget(contactForm.name) }}
        </div>
        <div class="form-group">
            {{ form_label(contactForm.email) }}
            {{ form_widget(contactForm.email) }}
        </div>
        <div class="form-group">
            {{ form_label(contactForm.message) }}
            {{ form_widget(contactForm.message) }}
        </div>

        <div class="form-group">
            <input type="submit" value="Send" class="btn btn-primary py-3 px-5">
        </div>


        {{ form_end(contactForm) }}
    </div>
{% endblock %}
