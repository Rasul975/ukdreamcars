<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" integrity="sha384-k6RqeWeci5ZR/Lv4MR0sA0FfDOMARE2QlfKkn5d1KAkH1Z0flcD+eZE1fprcQ0xM" crossorigin="anonymous">
        <link rel="stylesheet" href="styles.css">
    {% endblock %}
    {% block customPageStylesheet %}{% endblock %}


    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    {% endblock %}

    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDK6ffRzpsre3mBa_hI-nxKZY22-p02ghU" defer></script>
    <!-- Include the custom JavaScript file -->



</head>
<body>
<header class="bg-dark text-white">
    <div class="container">
        <div class="row py-2 align-items-center">
            <div class="col-6 d-flex align-items-center">
                <a href="#" class="text-white me-3"><i class="fab fa-facebook"></i></a>
                <a href="#" class="text-white me-3"><i class="fab fa-instagram"></i></a>
                <a href="#" class="text-white"><i class="fas fa-envelope"></i></a>
            </div>
            <div class="col-6 text-end">
                <span><i class="fas fa-map-marker-alt"></i> Mill Green Street, Ardwick, Manchester, M12 6FB</span>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container">
            <a class="navbar-brand me-auto" href="{{ path('app_home') }}">
                <img src="{{ asset('images/logo.png') }}" alt="Logo" height="50">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_inventory') }}">Showroom</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_part_exchange') }}">Part Exchange</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_previously_sold') }}">Previously Sold</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_about') }}">About Us</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_find_us') }}">Find Us</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_contact_us') }}">Contact Us</a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_admin') }}">Admin</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>
</header>

{% block wide %}{% endblock %}

<div class="content-wrapper d-flex flex-column min-vh-100">
    <!-- Main content of the page -->
    <main class="flex-grow-1">
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-dark text-white pt-5 mt-3">
        <div class="container">
            <div class="row">
                <div class="col-12 text-center mb-4">
                    <h2 class="text-uppercase">Looking for the perfect car?</h2>
                    <p>Call us on: 07882 016244</p>
                </div>
            </div>
            <div class="row text-center">
                <div class="col-6 col-md-3">
                    <h5><a href="{{ path('app_home') }}">Home</a></h5>
                    <h5><a href="{{ path('app_inventory') }}">Inventory</a></h5>
                </div>
                <div class="col-6 col-md-3">
                    <h5><a href="{{ path('app_sell_your_car') }}">Sell Your Car</a></h5>
                    <h5><a href="{{ path('app_testimonials') }}">Testimonials</a></h5>
                </div>
                <div class="col-6 col-md-3">
                    <h5><a href="{{ path('app_previously_sold') }}">Previously Sold</a></h5>
                    <h5><a href="{{ path('app_find_us') }}">Find us</a></h5>
                </div>
                <div class="col-6 col-md-3">
                    <h5><a href="{{ path('app_about') }}">About Us</a></h5>
                    <h5><a href="{{ path('app_contact_us') }}">Contact Us</a></h5>
                </div>
                <div class="col-6 col-md-3">
                    {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                        <h5><a href="{{ path('app_logout') }}">Logout</a></h5>
                    {% else %}
                        <h5><a href="{{ path('app_login') }}">Login/Register</a></h5>
                    {% endif %}
                </div>
            </div>
            <div class="row mt-4 text-center">
                <div class="col-12 col-md-4">
                    <h5>Address</h5>
                    <p>Mill Green Street<br>Ardwick<br>Manchester<br>M12 6FB</p>
                </div>
                <div class="col-12 col-md-4">
                    <h5>Contact</h5>
                    <p>T: 07882 016244<br>E: info@ukdreamcars.co.uk</p>
                </div>
                <div class="col-12 col-md-4">
                    <h5>Follow Us</h5>
                    <a href="https://www.facebook.com/profile.php?id=61559381182684" target="_blank" class="text-white me-2">Facebook<i class="fab fa-facebook text-white"></i></a>
                    <a href="https://www.instagram.com/uk_dream_cars/" target="_blank" class="text-white me-2">Instagram<i class="fab fa-instagram text-white"></i></a>
                    <a href="mailto:info@ukdreamcars.co.uk" class="text-white">Email<i class="fas fa-envelope text-white"></i></a>
                </div>
            </div>
            <div class="row mt-4 text-center">
                <div class="col-12">
                    <h5>Our Partners</h5>
                    <a href="#" class="text-white me-2">Warranty Assist</a>
                </div>
            </div>
        </div>
    </footer>
</div>

<script src="https://kit.fontawesome.com/a076d05399.js"></script>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="{{ asset('app.js') }}" defer></script>


{% block pageJavascripts %}{% endblock %}
</body>
</html>
