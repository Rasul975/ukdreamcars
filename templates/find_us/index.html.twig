{% extends 'base.html.twig' %}

{% block title %}Find Us{% endblock %}

{% block customPageStylesheet %}
    <style>
        #map {
            height: 400px;  /* Adjust the height as needed */
            width: 100%;
        }
        #directions-button {
            margin-top: 20px;
            display: inline-block;
            padding: 10px 20px;
            background-color: #4285F4;
            color: white;
            text-align: center;
            text-decoration: none;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            cursor: pointer;
        }
        #directions-button:hover {
            background-color: #357ae8;
        }
    </style>
{% endblock %}

{% block pageJavascripts %}
    <script src="https://maps.googleapis.com/maps/api/js?key={{ google_maps_api_key }}&callback=initMap" async defer></script>
    <script>
        function initMap() {
            const location = { lat: 53.474722, lng: -2.219030 };  // Set the coordinates for your location
            const map = new google.maps.Map(document.getElementById('map'), {
                zoom: 18,
                center: location
            });
            const marker = new google.maps.Marker({
                position: location,
                map: map
            });
        }

        function getDirections() {
            const destination = '53.474722,-2.219030';  // Set the coordinates for your location
            const url = `https://www.google.com/maps/dir/?api=1&destination=${destination}`;
            window.open(url, '_blank');
        }
    </script>
{% endblock %}

{% block body %}
    <h1>Find us</h1>
    <div id="map"></div>
    <button id="directions-button" onclick="getDirections()">Get Directions</button>
{% endblock %}
